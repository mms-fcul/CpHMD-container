Bootstrap: docker
From: ubuntu:24.04
Stage: Base-build

%post
    export DEBIAN_FRONTEND=noninteractive

    apt-get update -y
    apt-get upgrade -y
    apt-get install -y \
        bash \
        bc \
        build-essential \
        ca-certificates \
        cmake \
        curl \
        file \
        gawk \
        gcc \
        gfortran \
        git \
        libfftw3-dev \
        libopenmpi-dev \
        make \
        openmpi-bin \
        openmpi-common \
        perl \
        python3 \
        python3-dev \
        tar \
        wget \
        && apt-get clean -y \
        && rm -rf /var/lib/apt/lists/*

    ln -sf /CpHMD/scripts/CpHMD.sh /usr/local/bin/CpHMD.sh

    # Build Petit natively for aarch64
    test -f /programs/petit1.6.1/petit.c
    rm -f /programs/petit1.6.1/petit /programs/petit1.6.1/petit-gcc
    gcc -O2 /programs/petit1.6.1/petit.c -o /programs/petit1.6.1/petit || \
    gcc -O2 /programs/petit1.6.1/petit.c -lm -o /programs/petit1.6.1/petit
    cp -f /programs/petit1.6.1/petit /programs/petit1.6.1/petit-gcc
    chmod 755 /programs/petit1.6.1/petit /programs/petit1.6.1/petit-gcc

    # Build GROMACS 2024.3 natively for aarch64 (CPU-only)
    if [ ! -f /opt/src/gromacs/gromacs-2024.3.tar.gz ]; then
        echo "ERROR: missing /opt/src/gromacs/gromacs-2024.3.tar.gz inside container build"
        exit 1
    fi
    
    mkdir -p /opt/build-gromacs
    tar -xzf /opt/src/gromacs/gromacs-2024.3.tar.gz -C /opt/build-gromacs
    mkdir -p /opt/build-gromacs/gromacs-2024.3/build
    cd /opt/build-gromacs/gromacs-2024.3/build
    
    cmake .. \
        -DCMAKE_INSTALL_PREFIX=/gromacs \
        -DGMX_BUILD_OWN_FFTW=OFF \
        -DGMX_FFT_LIBRARY=fftw3 \
        -DGMX_MPI=OFF \
        -DGMX_OPENMP=ON \
        -DGMX_GPU=OFF \
        -DGMX_SIMD=None \
        -DGMXAPI=OFF \
        -DBUILD_SHARED_LIBS=ON \
        -DCMAKE_BUILD_TYPE=Release
    
    GMX_BUILD_JOBS="${SLURM_CPUS_PER_TASK:-4}"
    if [ "${GMX_BUILD_JOBS}" -gt 8 ]; then
        GMX_BUILD_JOBS=8
    fi
    make -j"${GMX_BUILD_JOBS}"
    make install
    
    cd /
    rm -rf /opt/build-gromacs /opt/src/gromacs

    # Remove known x86-specific Delphi runtime baggage
    rm -f /Delphi/libc.so.6
    echo "Delphi payload after cleanup:"
    file /Delphi/* || true

    # Install ARM Delphi helper binaries
    cp -f /Delphi/geom_center.arm64 /Delphi/geom_center
    cp -f /Delphi/calc_pkg_low.arm64 /Delphi/calc_pkg_low
    cp -f /Delphi/delphi95.arm64 /Delphi/delphi_pgf90
    chmod 755 /Delphi/geom_center /Delphi/calc_pkg_low /Delphi/delphi_pgf90
    
    # Remove staging copies
    rm -f /Delphi/geom_center.arm64 /Delphi/calc_pkg_low.arm64 /Delphi/delphi95.arm64
    
    # Show final Delphi binary architectures
    echo "Final Delphi runtime payload:"
    file /Delphi/geom_center /Delphi/calc_pkg_low /Delphi/delphi_pgf90 || true

    unset DEBIAN_FRONTEND

%environment
    export PATH="/gromacs/bin:/CpHMD/scripts:/usr/local/bin:/usr/bin:/bin:${PATH}"
    export LD_LIBRARY_PATH="/opt/nvhpc/lib:${LD_LIBRARY_PATH}"

%files
    container_build/compile-files/CpHMD_v3.3.2-container/ /CpHMD
    container_build/compile-files/DelphiTools_v3.3.1-container/ /Delphi
    container_build/compile-files/FFs/ /FFs
    container_build/compile-files/STs /STs
    container_build/compile-files/Databases /Databases
    container_build/compile-files/analysis/ /analysis
    template/ /Tutorials
    container_build/compile-files/petit1.6.1/ /programs/petit1.6.1
    container_build/sources/gromacs-2024.3.tar.gz /opt/src/gromacs/gromacs-2024.3.tar.gz
    container_build/compile-files/Delphi_helpers-arm64/geom_center /Delphi/geom_center.arm64
    container_build/compile-files/Delphi_helpers-arm64/calc_pkg_low /Delphi/calc_pkg_low.arm64
    container_build/compile-files/Delphi_pgf95-arm64/delphi95.arm64 /Delphi/delphi95.arm64
    
    container_build/compile-files/nvhpc-runtime-arm64/libnvcpumath.so /opt/nvhpc/lib/libnvcpumath.so
    container_build/compile-files/nvhpc-runtime-arm64/libnvc.so /opt/nvhpc/lib/libnvc.so
    container_build/compile-files/nvhpc-runtime-arm64/libnvf.so /opt/nvhpc/lib/libnvf.so
    container_build/compile-files/nvhpc-runtime-arm64/libnvhpcatm.so /opt/nvhpc/lib/libnvhpcatm.so
    container_build/compile-files/nvhpc-runtime-arm64/libnvmalloc.so /opt/nvhpc/lib/libnvmalloc.so
    container_build/compile-files/nvhpc-runtime-arm64/libnvomp.so /opt/nvhpc/lib/libnvomp.so

#############################
## create protonation app
#############################
%apprun protonation
    /analysis/extract_protonation.sh "$1" "$2"

%apphelp protonation
    Protonation is a command from the CpHMD container that treats the
    simulation .occ file. This file contains the tautomer used for each
    simulation segment and allows interpretation of protonation states.
    USAGE: singularity run --app protonation CpHMD.sif <.occ file> <.sites file>

######################################
## Extract protonation treatment file
######################################
%apprun extract-protonation-script
    cp -rf /analysis/extract_protonation.sh ./

%apphelp extract-protonation-script
    This app copies the script that treats protonation from the container
    into the current directory.

######################################
## Extract FF files
######################################
%apprun extract-force-fields
    case "$1" in
        GROMOS|Gromos|gromos)
            cp -rf /FFs/G54a7pH.ff ./G54a7pH.ff
            ;;
        CHARMM|Charmm|charmm)
            cp -rf /FFs/CHARMM36pH.ff ./CHARMM36pH.ff
            ;;
        AMBER|Amber|amber)
            cp -rf /FFs/Amber14SBpH.ff ./Amber14SBpH.ff
            ;;
        ""|*)
            echo "Missing or invalid force field. Use one of: GROMOS, CHARMM, AMBER."
            ;;
    esac

%appenv extract-force-fields
    SOFTWARE=extract-force-fields
    export SOFTWARE

%apphelp extract-force-fields
    This app copies the specified force field from the container to the current directory.

######################################
## Extract tautomer/state files
######################################
%apprun extract-tautomers
    case "$1" in
        GROMOS|Gromos|gromos)
            cp -rf /STs/St-G54a7pH ./STs-G54a7pH
            ;;
        CHARMM|Charmm|charmm)
            cp -rf /STs/St-CHARMM36pH ./STs-CHARMM36pH
            ;;
        AMBER|Amber|amber)
            cp -rf /STs/St-Amber14SBpH ./STs-Amber14SBpH
            ;;
        ""|*)
            echo "Missing or invalid force field. Use one of: GROMOS, CHARMM, AMBER."
            ;;
    esac

%applabels extract-tautomers
    get-files tautomer

%appenv extract-tautomers
    SOFTWARE=extract-tautomers
    export SOFTWARE

%apphelp extract-tautomers
    This app copies the tautomer/state files from the container to the current directory.

########################################################
## Extract Delphi databases
########################################################
%apprun extract-databases
    mkdir -p ./Databases
    case "$1" in
        GROMOS|Gromos|gromos|G54a7pH)
            cp -rf /Databases/DataBaseT_G54a7pH.* ./Databases/
            ;;
        CHARMM|Charmm|charmm|CHARMM36pH)
            cp -rf /Databases/DataBaseT_CHARMM36pH.* ./Databases/
            ;;
        AMBER|Amber|amber|Amber14SBpH)
            cp -rf /Databases/DataBaseT_Amber14SBpH.* ./Databases/
            ;;
        ""|*)
            echo "Missing or invalid force field. Use one of: GROMOS, CHARMM, AMBER."
            ;;
    esac

%apphelp extract-databases
    This app copies the selected Delphi database files into ./Databases.

########################################################
## Extract tutorial/settings files
########################################################
%apprun get-tutorials
    cp -rf /Tutorials ./tutorials

%apphelp get-tutorials
    This app copies the available tutorial/settings files to ./tutorials.

########################################################
## Extract settings files
########################################################
%apprun get-settings
    cp -f /Tutorials/CpHMD-"$1".settings ./

%apphelp get-settings
    This app copies a CpHMD settings file to the current directory.
    Example: singularity run --app get-settings CpHMD.sif basic

######################################
## Prepare the pdb for minimization
######################################
%apprun pdb2cphmd
    /analysis/prepare-pdb.sh "$@"

%apphelp pdb2cphmd
    This app prepares a PDB for CpHMD processing.

########################################################
## Make_sites test script to check titrating residues
########################################################
%apprun make-sites
    /CpHMD/scripts/make_sites "$@"

%apphelp make-sites
    This app makes a .sites file showing which residues are identified to titrate.

######################################
## Add molecule database helper
######################################
%apprun add-mol-db
    /analysis/add-mol-database.sh "$@"
    echo "Please do not forget to extract the full databases from the container and add your new molecules to them."
    echo
    echo "Your CpHMD.settings should define the Databases path for your updated custom database."

%apphelp add-mol-db
    This app helps prepare additions to the molecule database.