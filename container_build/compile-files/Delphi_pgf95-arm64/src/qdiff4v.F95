!                 nonzeroes in inc_setbcmod_nitit.f95
!                 search for: if(temp3.gt.2500) qmap1(ix)=0. 
!                 2.Corrected coefficients in Taylor expansion in 
!                 inc_qqintmod_rdprm.f95 
!                 search for: chi1,chi2,chi3,chi4,or chi5.
!12/22/2011 Lin   Fixed problem of time calculation.(problem: when
!                 calculation crossed days, time was minus value)
!12/05/2011 Lin   This version is based on version 10:
!                 "if(ndv.gt.5) then"---> "if(ndv.gt.20) then" 
!                 (subroutine vwtms)
!                 change ibmx value from 4000000 to 100000000 
!                 (subroutine epsmak)
!                 "if (tmp.lt.1.e-6) then" ---> 
!                 "if (tmp.lt.1.e-6.and..false.) then" (subrouine nitit)
!12/02/2011 Lin   Added modpdb4 option in delphi, which make delphi 
!                 read 4 digits precision after decimal point and make 
!                 delphi be able to use PQR file generated by other 
!                 program.
!                 Merged Walter's f77 version with this f95 version.
!10/15/2011 Chuan changed header and made it consistent with the one 
!                 in 77. 
!10/07/2011 Lin   "if(ndv.gt.2) then"---> "if(ndv.gt.5) then" 
!                 (subroutine vwtms)
!                 change ibmx value from 1000000 to 4000000 
!                 (subroutine epsmak)
!09/15/2011 Maxim commented line 
!                 (if(itest2) write(6,*)'-->',iv,xn,delphipdb(iv)%rad3,
!                 ismin,radmax2) in the file inc_epsmakmod_setout.f95
!09/12/2011 Chuan Removed qdiffpar.f95 since it is NOT used any more.
!09/08/2011 Lin   In relfac, phimap1,phimap2,phimap3 were initialized
!09/02/2011 Lin   In nlener, added a line     sout(n)%value=carica
!08/30/2011 Lin   In clbtot
!                 txyz=chgpos(i)-sout(j)%xyz; dist=txyz.dot.txyz --->
!                 txyz=chgpos(i)-sout(n)%xyz; dist=txyz.dot.txyz
!#####################################################################

      !Main delphi program
      !Created by PK from qdiff4v.F file
      program qdiff

      !2011-05-05  Modules used in the program
      use qlog               
      use pointers           
      use operators_on_coordinates 
      use misc               
      use misc2
      use crgarrmod
      use encalcmod
      use epsmakmod
      use extrmmod
      use qqintmod
      use rdhmod
      use setbcmod
      use setcrgmod
      use setrcmod
      use wrtsitmod

      implicit none

      !2011-05-05  Declaration of additional local variables and arrays
      !            some of them may be obsolete (to be removed later)
      character(50) :: fnma(30)
      character(80) :: argnam
      integer :: ifnma(30),arglen, iargc
      !integer nmedia,nobject,ndistr,numbmol !in qlog module
      !integer :: idirectalg,icount1a,icount1b  !in qlog module

      type(coord) :: xn
      !real :: xn(3),dbval(0:1,0:6,0:1),sfd(5,0:1)
      !real :: cqplus(3),cqmin(3)

      !2011-05-10 Transfered to qlog module to make it accessible by
      !           subroutines
      !logical :: uniformdiel

      !2011-05-05 Allocatable arrays below are declared in pointers 
      !           module
      !dimension xn2(1),ibgrd(3,1)         
      !dimension rad3(1),chrgv2(1),idpos(1),db(6,1) 
      !dimension sf1(1),sf2(1),qval(ngcrg)
      !dimension chrgv4(1),scspos(3,1)
      !integer iqpos(ngcrg)
      !character*24 atinf(1)*15
      !b+++++++++++++++++++
      !integer crgatn(1),nqgrdtonqass(1)
      !real medeps(0:nmediamax),atmeps(1),qfact
      !character*96 dataobject(nobjectmax,2)
      !character*80 datadistr(ndistrmax)
      !
      !pointer based arrays
      !real limobject(1),cgbp(5,1),chgpos(3,1)
      !e+++++++++++++++++++
      !integer iepsmp(1)
      !logical*1 idebmap(1)
      !integer iatmmed(1)
      !real phimap(1),atmforce(3,1)
      !real phimap1(1),phimap2(1),phimap3(1)
      !integer neps(1),keps(1)

      !2011-06-14 Declarations added due to IMPLICIT NONE
      real :: debnum,difeps,denom,debfct,finish,finish2,rmaxdim
      real :: qfact,rmid,sixth,sixeps,finish3,finish4,finish5
      real*4  timediff, timearray(2), dtime
      integer :: i,ic,ico,imaxwrd,irm,ix,iz,noit

      icount1a=0;  icount1b=0;  start=0.0; timetot=0.0
      timediff = dtime( timearray) !for total time calculation
      call date_and_time(VALUES=values)
      start=values(5)*3600.+values(6)*60.+values(7)+values(8)/1000.

      !2011-06-14 In module extrmmod file inc_extrmmod_wrtprm.f95
      call wrt(1)

      tol=1.e-7 !tolerance in small numbers

      debug=.false. !debug flag
      if (debug) write(6,*)"WARNING: working in DEBUGging mode"

      !call rdlog(fnma,ifnma); find logical links..

      i=iargc();  argnam=" "
      if (i.gt.0)then
         call getarg(1,argnam); arglen=len_trim(argnam)
         !call namlen(argnam,arglen)
      end if

      !2011-04-14 Argument arglen is obsolete
      !2011-06-14 In module qquintmod
      call qqint(i,argnam)

      !create suitable pdb file, if necessary
      !2011-06-14 In module qquintmod
      if (icreapdb) call createpdb(repsout,numbmol)

      !set hash tables from size and charge files
      call rdhrad

      !2011-05-05   Arguments are not necessary
      !read in pdbfile and, if necesssary, assign charges/radii
      if(isolv) call rdhcrg

      uniformdiel=.true.
      !2011-05-05  Seems redundant left-over statement
      !i_iatmmed=memalloc(i_iatmmed,4,natmax)

      !2011-05-05 Arguments are not necessary, transfered via modules
      call setrc

      !debug tested      write(6,*) 'After setrc -->',nmedia
      !call setrc(natom,*999,nmedia,nobject,ndistr)

      idirectalg=1
      if (nmedia.gt.1) then
         write(6,*)'Attention, many dielectrics! Not all the surface&
                  & charges are facing the solution!!'
         idirectalg=1
      end if

      write(6,*)'Direct mapping of epsilon: (0/1)(n/y)',idirectalg

      !2011-05-05  Already allocated in the getatm subroutine 
      !            of setrc module
      !i_iatmmed=memalloc(i_iatmmed,4,natom+nobject)
      !epsin = repsin /epkt !!!!!
      epsin=medeps(1)

      call date_and_time(VALUES=values)
      finish=values(5)*3600.+values(6)*60.+values(7)+values(8)/1000.
      if(ideveloper) then
        write(6,*)' time to read in and/or assign rad/chrg=',&
            &finish-start,' s'
      else
        write(6,"(a,f10.2,a)")' time to read in and/or assign rad/chrg=',&
            &finish-start,' s' 
      end if 
 
      !2011-05-05 Size of allocatable array is defined in getatm 
      !           subroutine of module setrc
      !2011-05-06 Limobject is now derived-type array described
      !           in pointers module
      allocate(limobject(Nobject))

      !find box enclosing each object at this moment expressed in 
      !Angstrom
      !2011-05-08 Arguments are not necessary, transfered via modules
      call extrmobjects 

      !find extrema
      !2011-05-08  Arguments are not necessary, transfered via modules
      call extrm

      !2011-05-09 Using operations on coord type variables defined
      !           in module operators_on_coordinates 
      pmid=(cmax+cmin)/2.

      !calculate offsets
      !2011-05-09 Hash table is not necessary in module architecture
      call off(oldmid,pmid)

      !2011-05-09 Using operations on coord type variables defined
      !           in module operators_on_coordinates 
      cran=cmax-cmin

      !2011-05-10 Converted to coord type variables
      rmaxdim=2.*max(abs(cmax%x-oldmid%x),abs(cmin%x-oldmid%x),&
             &abs(cmax%y-oldmid%y),abs(cmin%y-oldmid%y),&
             &abs(cmax%z-oldmid%z),abs(cmin%z-oldmid%z))
      !rmaxdim=max(cran(1),cran(2),cran(3))

      !atpos=atom positions, oldmid=current midpoints, 
      !rmaxdim=largest dimension
      !rad3= radii in angstroms. calculate scale according to them and
      !      to the percent box fill

      if (igrid.eq.0) then
         if (scale.eq.10000.) scale=2.0
         if (perfil.eq.10000.) perfil=80.
         igrid=scale*100./perfil*rmaxdim
      else if(scale.eq.10000.) then
         if (perfil.eq.10000.) then
            scale=2.0
            perfil=100.*rmaxdim*scale/real(igrid-1)
         else
            scale=real(igrid-1)*perfil/(100.*rmaxdim)
         end if
      else
         perfil=100.*rmaxdim*scale/real(igrid-1)
      end if

      !calcolo quante deblen di soluzione sono contenute nel box
      if (deblen.lt.1000000.) then
         debnum=(100./perfil-1.)*rmaxdim/deblen

         if(ideveloper) then
           write(6,*)'Debye Lengths contained in the finite diff. box',&
               &debnum
         else
           write(6,"(a,f10.4)")&
               &' Debye Lengths contained in the finite diff. box',debnum
         end if

       end if

      !if(rionst.gt.0.0.and.exrad.lt.1.e-6)exrad=2.0

      irm=mod(igrid,2)
      if(irm.eq.0) igrid=igrid+1

      !2011-06-16 Parameter Ngrid is now obsolete due to allocatable 
      !           arrays
      !if (igrid.gt.ngrid) then
      !   igrid=ngrid
      !   write(6,*)'igrid = ',igrid,' exceeds ','ngrid = ',ngrid,'&
      !            & so reset'
      !   scale=real(igrid-1)*perfil/(100.*rmaxdim)
      !end if

      !added dependence by nmedia
      medeps(0)=epsout
      call wrtprm(cmin,cmax,cran)

      ngp=igrid*igrid*igrid+1
      nhgp=ngp/2
      nbgp=igrid*igrid+1

      !calculate offsets
      !call off(oldmid,*999) vecchio posto

      !2011-05-10 Using operations on coord type variables defined
      !           in module operators_on_coordinates 
      xl=oldmid-(1.0/scale)*real(igrid+1)*0.5
      xr=oldmid+(1.0/scale)*real(igrid+1)*0.5
      if ((cmin.vorlt.xl).or.(cmax.vorgt.xr)) write(6,*) &
         &'!!! WARNING: part of system outside the box!'
      !convert atom coordinates from angstroms to grid units
      !2011-05-10 Array is allocated using conventional F95 statement
      !           xn2 array of coord derived type (pointers module)
      !2011-06-16 Added allocation of xn1 array in order to deal with
      !           different names in real (atpos) and dummy (xn1) 
      !           arguments in following subroutines
      allocate(xn2(Natom),xn1(Natom))

      !2011-05-10 grdatm subroutine is included now in the main body
      !           is too small to keep meaningfully as a separate 
      !           subroutine  
      !call grdatm(natom,igrid,scale,oldmid/cmid)
      rmid=real((igrid+1)/2)
      !xn2 = atpos expressed  in grid units
      do i=1,Natom
         !2011-05-10 Using operations on coord type variables defined
         !           in module operators_on_coordinates 
         xn1(i)=delphipdb(i)%xyz
         xn2(i)=(delphipdb(i)%xyz-oldmid)*scale+rmid
      end do

      !write visual.txt to dialog with the GUI
      !call wrtvisual(natom,igrid,nobject,scale,oldmid,nmedia,epkt)
      !verify if dielectric is uniform 
      do i=0,nmedia-1
         if (medeps(i).ne.medeps(i+1)) uniformdiel=.false.
      end do

      !debug tested	write(6,*) '-->>>>>',igrid,scale,oldmid,rmid
      !do i=1,natom
      !   write(6,*)'--->>',i,delphipdb(i)%xyz,xn2(i)
      !end do

      !now pass uniformdiel to epsmak
      !make the epsmap, and also a listing of boundary elements, and
      !the second epsmap used for the molecular surface scaling

      !2011-05-10 Arrays are allocated using conventional F95 statement
      if(gaussian.eq.0) then
         allocate(iepsmp(igrid,igrid,igrid),idebmap(igrid,igrid,igrid))
         !print *,"gaussian=0"
         !print *,"inhomo=",inhomo
      else
         allocate(iepsmp(igrid,igrid,igrid),idebmap(igrid,igrid,igrid))
         allocate(gepsmp(igrid,igrid,igrid),gepsmp2(igrid,igrid,igrid))
         !print *,"gaussian=1"
         !print *,"inhomo=",inhomo
      endif
      !2011-05-10 Parameters transferred via modules qlog and pointers
      inhomo=1
      if(gaussian.eq.1.and..not.logs)then
         inhomo=0
      endif
1010  call epsmak
      !++++I have postponed crgarr to epsmak

      !make some charge arrays for boundary conditions etc.
      if (isolv) then
         !increased the starting dimension of crgatn and..+++++
         extracrg=0      
         if (ndistr.gt.0) extracrg=igrid**3

         !2011-05-30 Allocation of the arrays below is moved to the 
         !           body of crgarr subroutine, arrays are accessible 
         !           via pointers module. Sizes of arrays are 
         !           determined before allocation inside the crgarr 
         !           subroutine
         !i_crgatn=memalloc(i_crgatn,4,natom+extracrg)
         !i_chrgv2=memalloc(i_chrgv2,realsiz,4*(natom+extracrg))
         !i_nqgrdtonqass=memalloc(i_nqgrdtonqass,4,natom+extracrg)
         !i_atmeps=memalloc(i_atmeps,realsiz,natom+extracrg)
         !i_chgpos=memalloc(i_chgpos,realsiz,3*ncrgmx)

         !2011-05-30 Parameters transfered via qlog and pointers modules

         call crgarr

         if (logs.or.lognl) then
            ico=0

            do ic=1,nqass
               if ((chgpos(ic).vorlt.xl).or.(chgpos(ic).vorgt.xr)) then
                  if (crgatn(ic).lt.0) then
                     write (6,'(''!WARNING: distribution'',I4,&
                           &'' outside the box'')') (-crgatn(ic))
                  else
                     if (crgatn(ic).gt.natom) then
                        write(6,'(''WARNING:crg'',I4,'',object'',I4,&
                             &'' outside the box'',3f8.3)')&
                             &ic,(crgatn(ic)-natom),chgpos(ic)
                     else
                        write(6, '(''!!! WARNING : charge '',&
                             &a15,'' outside the box'')') &
                             &  delphipdb(crgatn(ic))%atinf
                     end if
                  end if

                  ico=1
               end if
            end do

            if (ico.gt.0.and.ibctyp.ne.3) then
               write(6,*)'CHARGES OUTSIDE THE BOX AND &
                         &NOT DOING FOCUSSING, THEREFORE STOP'
               stop
            end if
         end if
      end if

      !write details
      !2011-06-02 Subroutine wrtadt is short and called only once
      !           thus body of the subroutine transfered here 
      !----------------- wrtadt.f --------------------------------
      if(gaussian.eq.1.and.inhomo.eq.0.and.logs) then
         goto 2010
      endif
    
      write(6,*)'  '
      !write(6,*)'box fill      (%):',perfil
      !write(6,*)'xmin,xmax     (A):',cmin(1),cmax(1)
      !write(6,*)'ymin,ymax     (A):',cmin(2),cmax(2)
      !write(6,*)'zmin,zmax     (A):',cmin(3),cmax(3)
      !write(6,*)'x,y,z range   (A): ',cran(1),cran(2),cran(3)
      !write(6,*)'scale   (grids/A): ',scale
      !write(6,*)'Lattice box is centered in (A):',oldmid
      write(6,"(a,i10)")' number of atom coordinates read  :',natom

      if (isolv) then
         write(6,"(a,i10)")' total number of assigned charges :',nqass
         write(6,"(a,f10.4)")' net assigned charge              :',qnet
         write(6,"(a,f10.4)")' assigned positive charge         :',qplus
         write(6,"(a,3f10.4)")' centred at (gu)                  :',cqplus
         write(6,"(a,f10.4)")' assigned negative charge         :',qmin
         write(6,"(a,3f10.4)")' centred at (gu)                  :',cqmin
      end if

      write(6,*)'   '
2010  continue
      !----------- End of wrtadt.f -------------------------------

      if (isolv) then
         write(6,*) 'number of dielectric boundary points',ibnum

         if (iexun.and.(ibnum.eq.0)) then
            write(6,*) "exiting as no boundary elements and"
            write(6,*) "uniform dielectric exit flag has been set"
            finish = 0.

            call date_and_time(DATE=day,TIME=time,VALUES=values)
            finish2=values(5)*3600.+values(6)*60.+values(7)+&
                    &values(8)/1000.
            write(6,*)'  '

            if(ideveloper) then
               write(6,*)'total cpu time was ',finish2-start, ' s'
            else
               write(6,"(a,f10.2,a)")' total cpu time was ',finish2-start,' s'
            end if

            write(6,*)'  '
            write(6,*)'DelPhi exited at ',time(1:2),':',time(3:4),&
                      &':',time(5:6)

            stop
         end if

         !2011-06-02 Subroutine dbsfd is rather small and called only 
         !           once, thus body of this subroutine transfered here
         !call dbsfd(dbval,sfd)
         !------------------------------ dbsfd.f ---------------------
         debfct=epsout/(deblen*scale)**2
         difeps=epsin-epsout
         sixeps=epsout*6.0
         sixth=1.0/6.0

         if (rionst.gt.0.) then
            do iz=0,1
               do ix=1,3
                  denom= sixeps + ix*difeps + iz*debfct
                  dbval(0,ix,iz)= 0.0
                  dbval(1,ix,iz)= difeps/denom
                  sfd(ix,iz)=epsout/denom
               end do
            end do

            do iz=0,1
               do ix=4,5
                  denom= sixeps + ix*difeps + iz*debfct
                  dbval(1,ix,iz)= 0.0
                  dbval(0,ix,iz)= -difeps/denom
                  sfd(ix,iz)=epsin/denom
               end do
            end do
         else
            do iz=0,1
               do ix=1,5
                  denom= sixeps + ix*difeps 
                  dbval(0,ix,iz)= (epsout/denom) -sixth 
                  dbval(1,ix,iz)= (epsin/denom) - sixth
               end do
            end do
         end if
         !------------------------ End of dbsfd.f --------------------

         !nsp=ibnum+1000 this on average saves memory but might 
         !               encounter problems
         nsp=2*(ibnum+1)
         allocate(db(6,nsp),idpos(nsp),sf1(nhgp),sf2(nhgp))

         !2011-06-02 Parameters transfred via qlog and pointers modules
         call mkdbsf

         !make qval and other linear charge arrays for the solver
         allocate(phimap(igrid,igrid,igrid))
         phimap=0.
         if (isph) then
            call setfcrg
         else
            call setcrg
         endif

         if (allocated(nqgrdtonqass)) deallocate(nqgrdtonqass)

         call date_and_time(DATE=day,TIME=time,VALUES=values)
         finish3=values(5)*3600.+values(6)*60.+values(7)+values(8)/1000.

         if(ideveloper) then
            write(6,*) 'iepsmp to db, and charging done at',finish3-start,' s'
         else
            write(6,"(a,f10.2,a)")' iepsmp to db, and charging done at',finish3-start,' s'
         end if
         write(6,*) 'number of grid points assigned charge', icount1b
         !write dielectric map
         if (epswrt)then
            imaxwrd = igrid/16 + 1
            !allocate(neps(imaxwrd,igrid,igrid),
            !keps(imaxwrd,igrid,igrid)) 
            !these arrays has been allocated twice, the other one is in 
            !subroutine wrteps.
            call wrteps(imaxwrd,natom+nobject+2)
         endif

         !call chkeps(natom,atpos,rad3,ibnum,ibgrd,igrid,scale,radprb)
         !I can't get rid of iepsmp if I have to calculate the nonlin 
         !energy

         !calculate boundary conditions
         call setbc

         allocate(phimap1(nhgp),phimap2(nhgp),phimap3(ngp))

         allocate(ibndx(nbgp),ibndy(nbgp),ibndz(nbgp))

         !trasformati in interi
         if (iuspec) then
            spec=uspec
            write(6,*) "using entered value for relaxation of: ",spec
         else
            !2011-06-07 All parameters are accessible via qlog and 
            !           pointers modules
            !Main output spec and filled phimap(1,2,3) and ibnd(x,y,z) 
            !arrays 
            call relfac
         end if

         noit=int(7.8/log(1.0 + sqrt(1-spec)))
         write(6,*) 'estimated iterations to convergence',noit
         if(iautocon) nlit = noit
         allocate(bndx1(nbgp),bndx2(nbgp),bndx3(nbgp),bndx4(nbgp))

         finish=0.
         !2011-06-14 Timing commented out for the moment
         !finish=cputime(start)
         call date_and_time(DATE=day,TIME=time,VALUES=values)
         finish4=values(5)*3600.+values(6)*60.+values(7)+values(8)/1000.
         timediff = dtime( timearray)
         timetot=timetot+timediff
         write(6,*)'  '
         !write(6,*)'setup time was (sec) ',finish4-start

         if(ideveloper) then
            write(6,*)'setup time was ',timediff, ' s'
         else
            write(6,"(a,f10.2,a)")' setup time was',timediff,' s'
         end if


         write(6,*)'  '

         !iterate
         if (real(ibc)/ibnum.gt..3.and.iautocon) then
            nlit=nlit*ibc/(.3*ibnum)
            write(6,*)'Re-estimated iterations now :',nlit
         end if

         if (nnit.eq.0.or.rionst.lt.1.e-6) then
            call itit   
         else
            allocate(qmap1(nhgp),qmap2(nhgp),debmap1(nhgp),&
                     &debmap2(nhgp))
            if (noit.gt.50) then
               nlit=noit/2
               write(6,*)'Re-estimated iterations now :',nlit
            end if
            qfact=abs(qnet)*dble(ibc)/ibnum

            !2011-06-09 All other parameters are accessible via qlog and
            !pointers modules
            call nitit(qfact)
            deallocate(qmap1,qmap2,debmap1,debmap2)
         end if

         deallocate(bndx1,bndx2,bndx3,bndx4,ibndx,ibndy,ibndz)
         deallocate(phimap1,phimap2,phimap3,db,idpos,sf1,sf2)

         !++++++now encalc takes nmedia++++
         !2011-06-11 All parameters are accessible via qlog and pointers
         !modules
         call encalc

         if(gaussian.eq.1.and.inhomo.eq.1.and.logs) then
            inhomo=0

            if(allocated(ibgrd)) deallocate(ibgrd)
            if(allocated(atmcrg)) deallocate(atmcrg)
            if(allocated(chgpos)) deallocate(chgpos)
            if(allocated(crgatn)) deallocate(crgatn)
            if(allocated(atmeps)) deallocate(atmeps)
            if(allocated(chrgv2)) deallocate(chrgv2)
            if(allocated(phimap)) deallocate(phimap)
            if(allocated(gchrgp)) deallocate(gchrgp)
            if(allocated(gchrg)) deallocate(gchrg)
            if(allocated(qval)) deallocate(qval)
            if(allocated(iqpos)) deallocate(iqpos)
            if(allocated(gval)) deallocate(gval)
            if(allocated(cgbp)) deallocate(cgbp)
            goto 1010
         endif
         if (allocated(chrgv2)) deallocate(chrgv2)

         if (isite) then
            i=0
            if(isitsf) i=1

            !2011-06-12 All other parameters are accessible via qlog and
            !pointers modules
            call wrtsit(i)

            if(allocated(iatmmed)) deallocate(iatmmed)
         end if

         finish=0.
         !finish=cputime(start) !2011-06-14 timing commented out for the
         !moment

         !write potential map for the GUI
         !2011-06-14 Subroutine is empty, so commented out call 
         !wrtphiForGUI

         !if phiwrt set true then write potential map
         if (phiwrt) call wrtphi
         deallocate(idebmap,phimap)
      end if

      call date_and_time(DATE=day,TIME=time,VALUES=values)

      timediff = dtime( timearray)
      timetot=timetot+timediff

      finish5=values(5)*3600.+values(6)*60.+values(7)+values(8)/1000.
      write(6,*)'  '
      !write(6,*)' total cpu time was (sec) ',finish5-start

      if(ideveloper) then
         write(6,*)'total cpu time was ',timetot,' s'
      else
         write(6,"(a,f10.2,a)")' total cpu time was ',timetot,' s'
      end if

      write(6,*)'  '
      write(6,*)'DelPhi exited at ',time(1:2),':',time(3:4),':',&
                &time(5:6)


      if(allocated(ibgrd)) deallocate(ibgrd)
      if(allocated(atmcrg)) deallocate(atmcrg)
      if(allocated(chgpos)) deallocate(chgpos)
      if(allocated(crgatn)) deallocate(crgatn)
      if(allocated(atmeps)) deallocate(atmeps)
      if(allocated(chrgv2)) deallocate(chrgv2)
      if(allocated(phimap)) deallocate(phimap)
      if(allocated(gchrgp)) deallocate(gchrgp)
      if(allocated(gchrg)) deallocate(gchrg)
      if(allocated(qval)) deallocate(qval)
      if(allocated(iqpos)) deallocate(iqpos)
      if(allocated(gval)) deallocate(gval)
      if(allocated(cgbp)) deallocate(cgbp)
 
      stop
      end program qdiff
