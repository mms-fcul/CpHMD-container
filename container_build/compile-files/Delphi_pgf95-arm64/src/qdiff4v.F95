!                    write(14,'(i5,3f12.6)') 1, origin -->
!                                     write(14,'(i5,3f14.6)') 1, origin 
!                    write(14,'(6E23.15)')(phimap(i,j,k),k=1,igrid)-->
!                        write(14,'(6E13.5)')(phimap(i,j,k),k=1,igrid)
